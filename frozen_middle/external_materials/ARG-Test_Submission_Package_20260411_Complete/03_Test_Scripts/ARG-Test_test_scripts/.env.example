ARG_TEST_PROVIDER=mock
ARG_TEST_MODEL=mock-arg-test
ARG_TEST_CANDIDATES=3
ARG_TEST_ENABLE_REPAIR=true

# Leave empty to write into repo-local artifacts/ and outputs/.
# Recommended for formal runs: .local_runs/formal_openai
ARG_TEST_OUTPUT_ROOT=

# Required when ARG_TEST_PROVIDER=openai
OPENAI_API_KEY=

# Optional for OpenAI-compatible endpoints
OPENAI_BASE_URL=

# Optional request timeout in seconds
OPENAI_TIMEOUT_SECONDS=120
